{
  "name": "r2-sync",
  "version": "0.1.0",
  "description": "A clean Obsidian plugin starter for the future r2-sync implementation.",
  "keywords": [
    "obsidian",
    "obsidian-plugin"
  ],
  "license": "0BSD",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "rolldown -c --watch",
    "build": "tsc --noEmit --skipLibCheck && rolldown -c --environment BUILD:production",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "version": "node version-bump.mjs && git add package.json manifest.json versions.json",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1049.0",
    "obsidian": "1.12.3"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "rolldown": "1.0.0-rc.18",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0"
}
